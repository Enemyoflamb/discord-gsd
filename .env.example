# Discord bot credentials
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_OWNER_ID=
DISCORD_PARENT_CHANNEL_ID=

# Workspace root inside the same container/runtime as discord-gsd and gsd.
# The bot stores projectlist.json here and creates per-project directories under it.
GSD_PROJECT_DIR=/workspace/projects

# Optional overrides
# GSD_CLI_PATH=/usr/local/bin/gsd
# GSD_MODEL=
# GSD_BARE=false
# DISCORD_MESSAGE_CHUNK_SIZE=1500
# LOG_LEVEL=info
